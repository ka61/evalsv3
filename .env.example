# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored — NEVER commit real keys.
# Inspect (and the VS Code extension) load `.env` automatically, searching parent
# directories too, so the keys here apply to every example in this repo.

# --- model provider API keys ---
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
# GOOGLE_API_KEY=your-google-key

# --- Inspect defaults ---
INSPECT_EVAL_MODEL=openai/gpt-4o-mini   # default --model if you don't pass one
INSPECT_LOG_DIR=./logs                  # where .eval logs are written
INSPECT_LOG_LEVEL=info
