# Copy this file to `.env` and fill in your key(s). `.env` is gitignored — never
# commit it. Inspect and the helper scripts load `.env` automatically.

# ── RECOMMENDED: one key, any model (easiest switching) ───────────────────────
# OpenRouter proxies 300+ models behind a single key. Use model strings like:
#   openrouter/openai/gpt-5.4           openrouter/openai/gpt-5.5
#   openrouter/anthropic/claude-opus-4.8
#   openrouter/google/gemini-3.5-flash  openrouter/qwen/qwen3.6-flash
# Slugs change over time — confirm an id at https://openrouter.ai/models.
OPENROUTER_API_KEY=sk-or-...

# Default model for EVERY run (scripts + `inspect eval` with no --model).
# Change this one line to switch models everywhere. Use a vision-capable model
# (e.g. .../gpt-5.4 or .../gpt-5.4-mini) so the image examples (14–16, 20–22) work.
INSPECT_EVAL_MODEL=openrouter/openai/gpt-5.4-mini

# ── OR use native provider keys directly (optional) ───────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ── Inspect defaults ──────────────────────────────────────────────────────────
INSPECT_LOG_DIR=./logs
INSPECT_LOG_LEVEL=info
